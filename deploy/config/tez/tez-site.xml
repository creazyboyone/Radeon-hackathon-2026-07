<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>
  <property>
    <name>tez.lib.uris</name>
    <value>hdfs://mycluster/tez/tez.tar.gz</value>
  </property>
  <property>
    <name>tez.use.cluster.hadoop-libs</name>
    <value>true</value>
  </property>
  <property>
    <name>tez.am.resource.memory.mb</name>
    <value>256</value>
  </property>
  <!-- Tez AM/task 容器用 Java 21 (Hive 4.2 注入 add-opens, Java 8 不认) -->
  <property>
    <name>tez.am.launch.env</name>
    <value>JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64</value>
  </property>
  <property>
    <name>tez.task.launch.env</name>
    <value>JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64</value>
  </property>
</configuration>
