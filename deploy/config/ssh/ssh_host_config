# 宿主机 SSH 配置 — 复制到 ~/.ssh/config 或直接用 ssh -F 指定
# 使用方法: ssh -F deploy/config/ssh/ssh_host_config hadoop01
# 或:     ssh -i deploy/config/ssh/id_rsa -p 2222 root@localhost

Host hadoop01
    HostName localhost
    Port 2222
    User root
    IdentityFile deploy/config/ssh/id_rsa
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null

Host hadoop02
    HostName localhost
    Port 2223
    User root
    IdentityFile deploy/config/ssh/id_rsa
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null

Host hadoop03
    HostName localhost
    Port 2224
    User root
    IdentityFile deploy/config/ssh/id_rsa
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
